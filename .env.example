NODE_ENV=development
PORT=5000

# MongoDB Atlas — get from cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nexuschat?retryWrites=true&w=majority

# JWT — generate a strong random string (min 32 chars)
JWT_SECRET=replace_this_with_a_long_random_secret_key_32chars_min
JWT_EXPIRE=7d

# Anthropic API — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Cloudinary (optional, for avatar uploads) — cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (update for production)
CLIENT_URL=http://localhost:5173
